migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Native Android C++ build artifacts
**/.cxx/

# CMake build directories — contain absolute paths baked into CMakeCache.txt
# and must never be committed (CI checkouts will have different paths).
native_audio/build_mac/
packages/flutter_vst3/dart_vst_host/native/build/

# Downloaded FluidSynth Windows SDK (prebuilt binaries, ~5MB)
native_audio/fluidsynth_win64/

# Local-only documentation (not for public repo)
/docs/local/

# Claude Code local settings (contains user paths, API keys, etc.)
.claude/settings.local.json

# ADB device cache (per-machine)
.vscode/.adb_device
